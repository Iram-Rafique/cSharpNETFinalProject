@page "{id:int}"
@model Project.Pages.UpdateModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_Layout";
}
<div class="update-page">

    <h2>Update Album</h2>

    @if (Model.Album == null)
    {
        <p>Album not found.</p>
    }
    else
    {
        <div class="update-card">

            <form method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Album.AlbumId" />

                <div class="form-group">
                    <label>Album Title:</label>
                    <input asp-for="Album.Title" class="form-input" required />
                </div>

                <div class="form-group">
                    <label>Artist:</label>
                    <input list="artistList" name="ArtistName" class="form-input" required />

                    <datalist id="artistList">
                        @foreach (var artist in Model.Artists)
                        {
                            <option value="@artist.Name"></option>
                        }
                    </datalist>
                </div>

                <h3>Tracks</h3>

                <table class="update-track-table">
                    <tr>
                        <th>Track Name</th>
                    </tr>
                    @for (int i = 0; i < Model.Tracks.Count; i++)
                    {
                        <tr>
                            <td>
                                <input type="hidden" asp-for="Tracks[i].TrackId" />
                                <input type="text" asp-for="Tracks[i].Name" class="form-input" required />
                            </td>
                        </tr>
                    }
                </table>
@if (!Model.Tracks.Any())
{
    <p>No tracks found for this album.</p>
}
                <div class="button-group">
                    <button type="submit" class="btn">Save All</button>
                    <a asp-page="/Index" class="btn cancel-btn">Cancel</a>
                </div>

            </form>

        </div>
    }

</div>