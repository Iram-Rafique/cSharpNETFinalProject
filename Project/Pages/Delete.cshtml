@page "{AlbumID:int}"
@model Project.Pages.DeleteModel
@{
    Layout = "_Layout";
}

<div class="delete-page">
    <h2>Delete Album</h2>

    @if (Model.Album == null)
    {
        <p>No album found.</p>
    }
    else
    {
        <div class="album-info">
            <p><strong>Album:</strong> @Model.Album.Title</p>
            <p><strong>Artist:</strong> @Model.Album.Artist.Name</p>

            @if (Model.Tracks != null && Model.Tracks.Any())
            {
                <h3>Tracks</h3>
                <table class="delete-track-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Track Name</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Tracks.Count; i++)
                        {
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@Model.Tracks[i].Name</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>No tracks found.</p>
            }
        </div>

        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="AlbumId" value="@Model.Album.AlbumId" />
            <p>Are you sure you want to delete this album?</p>
            <button type="submit" name="confirm" value="yes" class="delete-btn confirm">Yes</button>
            <button type="button" class="delete-btn cancel" onclick="window.location.href='/Index'">No</button>
        </form>
    }
</div>