@page "{AlbumID:int}"
@model Project.Pages.DeleteModel

<h1>Delete Album</h1>

@if (Model.Album == null)
{
    <p>No album found.</p>
}
else
{
    <p><strong>Album:</strong> @Model.Album.Title</p>
    <p><strong>Artist:</strong> @Model.Album.Artist.Name</p>

    @if (Model.Tracks.Any())
    {
        <p><strong>Tracks:</strong></p>
        <ul>
            @foreach (var t in Model.Tracks)
            {
                <li>@t.Name</li>
            }
        </ul>
    }
    else
    {
        <p>No tracks found.</p>
    }

    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="AlbumId" value="@Model.Album.AlbumId" />
        <p>Are you sure you want to delete this album?</p>
        <button type="submit" name="confirm" value="yes">Yes</button>
        <a asp-page="/Index"><button type="button">No</button></a>
    </form>
}