@page
@model Project.Pages.InsertModel
@using albumsEntities

<h1>Insert Album and Tracks</h1>

<form method="post">
    @Html.AntiForgeryToken()

    <!-- album Section -->
    <label>Album Title:
        <input type="text" name="tbxAlbumTitle" required />
    </label>
    <br /><br />

    <!-- artist Section -->
    <label>Artist:
        <input list="artists" name="tbxArtist" placeholder="Select or type artist" />
        <datalist id="artists">
            @foreach (var artist in Model.Artists)
            {
                <option value="@artist.Name">@artist.Name</option>
            }
        </datalist>
    </label>
    <br /><br />

    <!-- tracks Section -->
    <div id="tracks-container">
        <label>Track Name:
            <input type="text" name="tbxTrackNames" />
        </label>
    </div>
    <br />
    <button type="button" onclick="addTrack()">Add Another Track</button>
    <br /><br />

    <input type="submit" value="Insert Album and Tracks" />
</form>
   <a href="/Index">Back to Albums</a>
<script>
function addTrack() {
    const container = document.getElementById('tracks-container');

    // Create input
    const input = document.createElement('input');
    input.type = 'text';
    input.name = 'tbxTrackNames';
    input.placeholder = 'Track Name';

    // Create delete button
    const deleteBtn = document.createElement('button');
    deleteBtn.type = 'button';
    deleteBtn.textContent = 'Delete';
    deleteBtn.onclick = () => {
        container.removeChild(input);
        container.removeChild(deleteBtn);
    };

    // Add to container
    container.appendChild(document.createElement('br'));
    container.appendChild(input);
    container.appendChild(deleteBtn);
}
</script>