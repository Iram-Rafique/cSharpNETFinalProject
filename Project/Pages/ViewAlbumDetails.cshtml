@* route pram *@
@page "{AlbumID:int}"   
@model Project.Pages.ViewAlbumDetailsModel
@{
    Layout = "_Layout";
}

<h2>Album Details</h2>

@if (Model.Album == null)
{
    <p>No album found.</p>
}
else
{
    <div class="album-card">
        <p>
            <strong>Title:</strong> @Model.Album.Title
        </p>
        <p>
            <strong>Artist:</strong> @Model.Album.Artist.Name
        </p>
    </div>
@* tracks *@
    <h2>Tracks</h2>

    @if (Model.Tracks == null || !Model.Tracks.Any())
    {
        <p>No tracks available for this album.</p>
    }
    else
    {
        <table class="track-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Track Name</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Tracks.Count; i++)
                {
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@Model.Tracks[i].Name</td>
                    </tr>
                }
            </tbody>
        </table>
        //back to hom page
       
    }
     <a href="/Index">Back to Albums</a>
}